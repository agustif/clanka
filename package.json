{
  "name": "clanka",
  "type": "module",
  "version": "0.1.7",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "clanka": "./bin/clanka"
  },
  "scripts": {
    "prepare": "husky && effect-language-service patch",
    "lint": "oxlint -c .oxlintrc.json",
    "lint:fix": "oxlint -c .oxlintrc.json --fix",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest run",
    "validate": "bun run lint && bun run typecheck && bun run test",
    "check": "bun run validate",
    "build": "tsc -b tsconfig.json",
    "example:cli": "bun run examples/cli.ts",
    "example:tui": "bun run examples/tui.ts",
    "smoke:cli": "bun run bin/clanka --cli --mock",
    "smoke:tui": "bun run bin/clanka --mock --once",
    "tui": "bun run bin/clanka",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist",
    "src",
    "bin"
  ],
  "description": "Bun-first Effect-native agent runtime with typed tool execution, provider layers, and a secondary TypeBuilder utility.",
  "license": "GPL-3.0-only",
  "author": "Tim Smart <hello@timsmart.co>",
  "homepage": "https://github.com/agustif/clanka",
  "repository": {
    "type": "git",
    "url": "https://github.com/agustif/clanka.git"
  },
  "packageManager": "bun@1.3.9",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@effect/platform-bun": "4.0.0-beta.31",
    "@vscode/ripgrep": "^1.17.0",
    "chalk": "^5.6.2",
    "glob": "^13.0.6",
    "turndown": "^7.2.2"
  },
  "peerDependencies": {
    "@effect/ai-openai": "4.0.0-beta.31",
    "@effect/ai-openai-compat": "4.0.0-beta.31",
    "effect": "4.0.0-beta.31"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@effect/ai-openai": "4.0.0-beta.31",
    "@effect/ai-openai-compat": "4.0.0-beta.31",
    "@effect/language-service": "^0.75.1",
    "@effect/platform-node": "4.0.0-beta.31",
    "@effect/vitest": "4.0.0-beta.31",
    "@linear/sdk": "^75.0.0",
    "@types/node": "^25.3.5",
    "@types/turndown": "^5.0.6",
    "@typescript/native-preview": "7.0.0-dev.20260219.1",
    "effect": "4.0.0-beta.31",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxlint": "^1.49.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
